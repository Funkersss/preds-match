# Database — Vercel Postgres connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Football API — https://www.football-data.org/client/register
FOOTBALL_API_KEY="your-football-data-org-api-key"

# Admin panel password
ADMIN_PASSWORD="change-me-to-a-secure-password"

# Resend — https://resend.com
RESEND_API_KEY="re_your_resend_api_key"

# Email sender address (optional, defaults to onboarding@resend.dev)
EMAIL_FROM="Predict the Match <noreply@yourdomain.com>"

# Admin email for alerts (optional)
ADMIN_EMAIL="admin@yourdomain.com"

# Cron job secret — set this in Vercel project settings
CRON_SECRET="your-cron-secret"
